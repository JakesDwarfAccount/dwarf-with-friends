{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dwarf-with-friends.local/ground-truth/schema/v1/decision.schema.json",
  "type": "object",
  "required": ["schemaVersion", "recordType", "id", "title", "status", "rationale", "nativeIds", "evidenceRefs", "decidedBy", "decidedOn", "supersedes"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "recordType": { "const": "decision" },
    "id": { "$ref": "common.schema.json#/$defs/decisionId" },
    "title": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "status": { "enum": ["proposed", "approved", "rejected", "superseded"] },
    "rationale": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "nativeIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/entityId" } },
    "evidenceRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/evidenceRef" } },
    "decidedBy": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "decidedOn": { "$ref": "common.schema.json#/$defs/date" },
    "supersedes": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/decisionId" } }
  }
}
