{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dwarf-with-friends.local/ground-truth/schema/v1/evidence.schema.json",
  "type": "object",
  "required": ["schemaVersion", "recordType", "id", "kind", "buildId", "source", "selectors", "producer", "createdAt", "structuralValidation"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "recordType": { "const": "evidence" },
    "id": { "$ref": "common.schema.json#/$defs/evidenceId" },
    "kind": { "enum": ["binary", "corpus", "catalog", "human-review", "negative-finding"] },
    "buildId": { "$ref": "common.schema.json#/$defs/buildId" },
    "source": {
      "type": "object",
      "required": ["contentSha256", "privateLocator"],
      "additionalProperties": false,
      "properties": {
        "contentSha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "privateLocator": { "type": "string", "pattern": "^(oracle|recorder|vault|review)://[A-Za-z0-9._~:/?#@!$&'()*+,;=%-]+$" }
      }
    },
    "selectors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "functionAddresses": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" } },
        "instructionAddresses": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" } },
        "frameIds": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
        "catalogIds": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
        "reviewIds": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" }
      }
    },
    "producer": {
      "type": "object",
      "required": ["tool", "version"],
      "additionalProperties": false,
      "properties": {
        "tool": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "version": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "captureContext": {
      "type": "object",
      "required": ["pluginBuild", "recorderSchemaVersion"],
      "additionalProperties": false,
      "properties": {
        "pluginBuild": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "recorderSchemaVersion": { "type": "integer", "minimum": 1 }
      }
    },
    "gateBinding": {
      "type": "object",
      "required": ["taskId", "requirementId", "nativeIds", "factOrCaseIds", "implementationCommit", "artifactSha256s"],
      "additionalProperties": false,
      "properties": {
        "taskId": { "$ref": "common.schema.json#/$defs/taskId" },
        "requirementId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "nativeIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/entityId" } },
        "factOrCaseIds": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
        "implementationCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "artifactSha256s": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/sha256" } },
        "reducer": { "type": "object", "required": ["name", "version", "resultSha256"], "additionalProperties": false, "properties": { "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "version": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "resultSha256": { "$ref": "common.schema.json#/$defs/sha256" } } },
        "reviewer": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "verdict": { "enum": ["approved", "rejected"] }
      }
    },
    "createdAt": { "$ref": "common.schema.json#/$defs/dateTime" },
    "structuralValidation": {
      "type": "object",
      "required": ["passed", "method"],
      "additionalProperties": false,
      "properties": {
        "passed": { "type": "boolean" },
        "method": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    }
  }
}
