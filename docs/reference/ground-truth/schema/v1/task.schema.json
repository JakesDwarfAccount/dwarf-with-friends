{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dwarf-with-friends.local/ground-truth/schema/v1/task.schema.json",
  "type": "object",
  "required": ["schemaVersion", "recordType", "id", "taskKind", "lifecycle", "pins", "nativeIds", "mappingIds", "acceptedFacts", "uncertainties", "counterexamples", "absenceGuards", "files", "requirements", "nonGoals", "forbiddenEvidenceEdits"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "recordType": { "const": "task" },
    "id": { "$ref": "common.schema.json#/$defs/taskId" },
    "taskKind": { "enum": ["research", "implementation", "mapping-audit", "live-review", "final-verification", "audit"] },
    "lifecycle": {
      "type": "object",
      "required": ["stage", "mayPromote", "requiredReissueStages"],
      "additionalProperties": false,
      "properties": {
        "stage": { "enum": ["research", "implementation", "mapping-audit", "live-review", "final-verification", "audit"] },
        "mayPromote": { "type": "boolean" },
        "requiredReissueStages": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" }
      }
    },
    "pins": {
      "type": "object",
      "required": ["buildId", "executableSha256", "registrySha256", "evidenceIndexSha256", "registryCommit", "implementationBaseCommit", "verifierCommit", "schemasSha256", "reducersSha256", "verifierFixturesSha256", "commandManifestSha256"],
      "additionalProperties": false,
      "properties": {
        "buildId": { "$ref": "common.schema.json#/$defs/buildId" },
        "executableSha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "registrySha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "evidenceIndexSha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "registryCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "implementationBaseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "verifierCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "schemasSha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "reducersSha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "verifierFixturesSha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "commandManifestSha256": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    },
    "nativeIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/entityId" } },
    "mappingIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/mappingId" } },
    "acceptedFacts": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
    "uncertainties": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
    "counterexamples": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
    "absenceGuards": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
    "files": {
      "type": "object",
      "required": ["allowed", "exclusive", "verifierOwned"],
      "additionalProperties": false,
      "properties": {
        "allowed": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/relativePath" } },
        "exclusive": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/relativePath" } },
        "verifierOwned": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/relativePath" } }
      }
    },
    "requirements": {
      "type": "object",
      "required": ["fixtures", "predicates", "sourceCitations", "sourceWitnesses", "binaryWitnesses", "commands", "supplementalCommands", "liveChecks", "humanReviews"],
      "additionalProperties": false,
      "properties": {
        "fixtures": { "type": "array", "uniqueItems": true, "items": { "type": "object", "required": ["id", "kind", "description"], "additionalProperties": false, "properties": { "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "kind": { "enum": ["positive", "boundary", "counterexample"] }, "description": { "$ref": "common.schema.json#/$defs/nonEmptyString" } } } },
        "predicates": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
        "sourceCitations": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
        "sourceWitnesses": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
        "binaryWitnesses": { "type": "array", "items": { "type": "object", "required": ["id", "literal"], "additionalProperties": false, "properties": { "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "literal": { "$ref": "common.schema.json#/$defs/nonEmptyString" } } } },
        "commands": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command" } },
        "supplementalCommands": { "type": "array", "items": { "$ref": "#/$defs/command" } },
        "liveChecks": { "type": "array", "items": { "$ref": "#/$defs/gateRequirement" } },
        "humanReviews": { "type": "array", "items": { "$ref": "#/$defs/gateRequirement" } }
      }
    },
    "nonGoals": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
    "forbiddenEvidenceEdits": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/relativePath" } }
  },
  "$defs": {
    "command": { "type": "object", "required": ["id", "executable", "args", "parser", "owner"], "additionalProperties": false, "properties": { "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "executable": { "$ref": "common.schema.json#/$defs/relativePath" }, "args": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" } }, "parser": { "enum": ["ground-truth-check-v1", "supplemental-prose-v1"] }, "owner": { "enum": ["verifier", "implementation"] } } },
    "gateRequirement": { "type": "object", "required": ["id", "description", "nativeIds", "factOrCaseIds"], "additionalProperties": false, "properties": { "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "description": { "$ref": "common.schema.json#/$defs/nonEmptyString" }, "nativeIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/entityId" } }, "factOrCaseIds": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" } } }
  }
}
