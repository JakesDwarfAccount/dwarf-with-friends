{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dwarf-with-friends.local/ground-truth/schema/v1/mapping.schema.json",
  "type": "object",
  "required": ["schemaVersion", "recordType", "id", "nativeId", "applicability", "implementations", "disposition", "audit", "decisionRefs", "knownDeviations", "lastVerified"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "recordType": { "const": "mapping" },
    "id": { "$ref": "common.schema.json#/$defs/mappingId" },
    "nativeId": { "$ref": "common.schema.json#/$defs/entityId" },
    "applicability": { "$ref": "common.schema.json#/$defs/applicability" },
    "implementations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "file", "symbol", "assets", "tests"],
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["client", "server", "wire", "route", "component", "fixture", "test"] },
          "file": { "$ref": "common.schema.json#/$defs/relativePath" },
          "symbol": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "route": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "wireField": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "dfcuiComponent": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "assets": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
          "tests": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/relativePath" } }
        }
      }
    },
    "disposition": { "enum": ["absent", "partial", "implemented", "conflicting", "retired", "intentionally-not-supported"] },
    "audit": {
      "type": "object",
      "required": ["classification", "findings"],
      "additionalProperties": false,
      "properties": {
        "classification": { "enum": ["exact-candidate", "local-repair", "structural-repair", "rebuild-candidate", "intentional-deviation", "insufficient-evidence"] },
        "findings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" } }
      }
    },
    "decisionRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/decisionId" } },
    "knownDeviations": { "$ref": "common.schema.json#/$defs/nonEmptyStringList" },
    "lastVerified": {
      "type": "object",
      "required": ["buildId", "codeVersion"],
      "additionalProperties": false,
      "properties": {
        "buildId": { "$ref": "common.schema.json#/$defs/buildId" },
        "codeVersion": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    }
  }
}
